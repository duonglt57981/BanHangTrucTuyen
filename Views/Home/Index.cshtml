<!-- ===================== CATEGORY CARDS ===================== -->
<section class="cs-section">
    <p class="cs-section-label">Danh mục nổi bật</p>
    <h2 class="cs-section-title">Chọn danh mục</h2>

    <div class="cat-grid" id="catGrid">
        @{
            /* Màu gradient và icon cho từng danh mục */
            var catColors = new[] {
                "#1e40af,#0f172a",   // xanh navy
                "#7c2d12,#0f172a",   // nâu đỏ
                "#064e3b,#0f172a",   // xanh rừng
                "#4c1d95,#0f172a",   // tím
                "#92400e,#0f172a",   // vàng nâu
                "#0e7490,#0f172a",   // xanh biển
                };
            var catIcons = new[] {
                "fa-camera",
                "fa-camera-retro",
                "fa-video",
                "fa-ruler-combined",
                "fa-battery-full",
                "fa-wifi",
                };

            /* Gán màu dựa theo DanhMucID để ổn định */
            var danhMucDescriptions = new Dictionary<string, string>
                {
                { "máy ảnh",    "Máy ảnh DSLR, Mirrorless, compact từ các thương hiệu hàng đầu." },
                { "ống kính",   "Ống kính góc rộng, tele, macro, prime cho mọi nhu cầu sáng tác." },
                { "chân đế",    "Tripod, monopod, gorillapod giữ vững khung hình của bạn." },
                { "phụ kiện",   "Túi đựng, pin, thẻ nhớ, bộ lọc và nhiều phụ kiện khác." },
                { "đèn flash",  "Đèn flash rời, đèn studio chuyên nghiệp, bộ khuếch tán ánh sáng." },
                { "drone",      "Máy bay không người lái ghi lại góc nhìn trên cao ấn tượng." },
                };
        }

        @for (int i = 0; i < danhMucs.Count; i++)
        {
            var dm = danhMucs[i];
            var color = catColors[i % catColors.Length];
            var icon = catIcons[i % catIcons.Length];
            var spCount = Model?.Count(s => s.DanhMucID == dm.DanhMucID) ?? 0;

            /* tìm mô tả theo tên gần đúng */
            var desc = danhMucDescriptions
            .FirstOrDefault(kv => dm.TenDanhMuc.ToLower().Contains(kv.Key))
            .Value ?? "Khám phá các sản phẩm chất lượng trong danh mục này.";

            /* top 5 sản phẩm của danh mục */
            var topSps = Model?.Where(s => s.DanhMucID == dm.DanhMucID).Take(5).ToList()
            ?? new List<SanPham>();

            <div class="cat-card" tabindex="0"
                 data-dm-id="@dm.DanhMucID"
                 onclick="toggleCatCard(this)"
                 onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();toggleCatCard(this);}">

                <!-- Gradient banner -->
                <div class="cat-card-banner"
                     style="background: linear-gradient(135deg, @color)">
                </div>

                <!-- Floating icon -->
                <div class="cat-icon-wrap">
                    <i class="fas @icon"></i>
                </div>

                <!-- Card body -->
                <div class="cat-card-body">
                    <div class="cat-card-name">@dm.TenDanhMuc</div>
                    <div class="cat-card-count">@spCount sản phẩm</div>
                </div>

                <!-- Expanded details -->
                <div class="cat-details">
                    <p>@desc</p>
                    @if (topSps.Any())
                    {
                        <div class="cat-product-list">
                            @foreach (var sp in topSps)
                            {
                                <a href="@Url.Action("Details", "Home", new { id = sp.SanPhamID })"
                                   class="cat-product-chip"
                                   onclick="event.stopPropagation()">
                                    @sp.TenSanPham
                                </a>
                            }
                        </div>
                    }
                    <a href="@Url.Action("Index", "Home", new { danhMucId = dm.DanhMucID })"
                       class="cat-view-all" onclick="event.stopPropagation()">
                        <i class="fas fa-arrow-right"></i> Xem tất cả @dm.TenDanhMuc
                    </a>
                </div>

                <!-- Close button (only visible when expanded) -->
                <button class="cat-close" onclick="event.stopPropagation(); toggleCatCard(this.closest('.cat-card'))"
                        aria-label="Đóng">
                    &times;
                </button>
            </div>
        }
    </div>
</section>

<!-- ===================== PRODUCTS ===================== -->
<section class="prod-section">
    <div class="prod-toolbar">
        <div class="prod-toolbar-title">
            @if (ViewBag.CurrentDanhMuc != null)
            {
                var activeDm = danhMucs.FirstOrDefault(d => d.DanhMucID == (int)ViewBag.CurrentDanhMuc);
                <span>@(activeDm?.TenDanhMuc ?? "Sản phẩm")</span>
            }
            else
            {
                <span>Tất cả sản phẩm</span>
            }
        </div>
        <div class="prod-toolbar-right">
            <a asp-action="Index"
               asp-route-danhMucId="@ViewBag.CurrentDanhMuc"
               asp-route-searchString="@ViewBag.CurrentSearch"
               asp-route-sortOrder=""
               class="sort-pill @(string.IsNullOrEmpty(ViewBag.CurrentSort?.ToString()) ? "active" : "")">
                Mới nhất
            </a>
            <a asp-action="Index"
               asp-route-danhMucId="@ViewBag.CurrentDanhMuc"
               asp-route-searchString="@ViewBag.CurrentSearch"
               asp-route-sortOrder="price_asc"
               class="sort-pill @(ViewBag.CurrentSort == "price_asc" ? "active" : "")">
                Giá ↑
            </a>
            <a asp-action="Index"
               asp-route-danhMucId="@ViewBag.CurrentDanhMuc"
               asp-route-searchString="@ViewBag.CurrentSearch"
               asp-route-sortOrder="price_desc"
               class="sort-pill @(ViewBag.CurrentSort == "price_desc" ? "active" : "")">
                Giá ↓
            </a>
            <a asp-action="Index"
               asp-route-danhMucId="@ViewBag.CurrentDanhMuc"
               asp-route-searchString="@ViewBag.CurrentSearch"
               asp-route-sortOrder="name_asc"
               class="sort-pill @(ViewBag.CurrentSort == "name_asc" ? "active" : "")">
                A → Z
            </a>
        </div>
    </div>

    <div class="prod-grid">
        @if (Model != null && Model.Any())
        {
            int pi = 0;
            @foreach (var item in Model)
            {
                pi++;
                var delay = (pi * 0.07).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
                <div class="prod-card" style="animation-delay:@(delay)s"
                     onclick="location.href='@Url.Action("Details", new { id = item.SanPhamID })'">

                    <div class="prod-img">
                        @if (item.HinhAnh != null && item.HinhAnh.Length > 0)
                        {
                            <img src="data:image/jpeg;base64,@Convert.ToBase64String(item.HinhAnh)"
                                 alt="@item.TenSanPham" />
                        }
                        else
                        {
                            <i class="fas fa-camera" style="font-size:3rem;color:#334155;"></i>
                        }

                        @if (item.TonKho <= 0)
                        {
                            <span class="prod-badge out">Hết hàng</span>
                        }
                        else if (item.TonKho < 10)
                        {
                            <span class="prod-badge"><i class="fas fa-fire"></i> Sắp hết</span>
                        }
                    </div>

                    <div class="prod-body">
                        <div class="prod-cat">@item.DanhMuc?.TenDanhMuc</div>
                        <div class="prod-name">@item.TenSanPham</div>
                        <div class="prod-price">@item.Gia.ToString("N0") đ</div>
                        <div class="prod-stock @(item.TonKho >= 10 ? "ok" : item.TonKho > 0 ? "low" : "")">
                            @if (item.TonKho <= 0)
                            {
                                <span><i class="fas fa-times-circle"></i> Hết hàng</span>
                            }
                            else if (item.TonKho < 10)
                            {

                                <span><i class="fas fa-exclamation-circle"></i> Còn @item.TonKho</span>
                            }
                            else
                            {

                                <span><i class="fas fa-check-circle"></i> Còn @item.TonKho</span>
                            }
                        </div>
                        <div class="prod-actions">
                            <a asp-action="Details" asp-route-id="@item.SanPhamID"
                               class="prod-btn-detail" onclick="event.stopPropagation()">
                                <i class="fas fa-info-circle"></i> Chi tiết
                            </a>
                            <button class="prod-btn-cart"
                                    onclick="event.stopPropagation(); addToCart(@item.SanPhamID)"
                                    @(item.TonKho <= 0 ? "disabled" : "")>
                                <i class="fas fa-cart-plus"></i> Thêm
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column:1/-1;text-align:center;padding:5rem 0;color:var(--muted);font-family:'DM Sans',sans-serif;">
                <i class="fas fa-search" style="font-size:3rem;margin-bottom:1rem;display:block;"></i>
                <h4 style="color:var(--text);">Không tìm thấy sản phẩm nào</h4>
                <p>Hãy thử tìm kiếm với từ khóa khác</p>
            </div>
        }
    </div>
</section>

