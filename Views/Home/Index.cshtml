@section Scripts {
    <script>
        /* =========================================================
           CATEGORY CARD TOGGLE (Jujutsu-style)
        ========================================================= */
        function toggleCatCard(card) {
            const current = document.querySelector('.cat-card.expanded');
            if (current && current !== card) return;

            const expanding = !card.classList.contains('expanded');
            const icon = card.querySelector('.cat-icon-wrap i');

            if (expanding) icon.style.transform = '';

            if (document.startViewTransition) {
                card.style.viewTransitionName = 'active-cat';
                const t = document.startViewTransition(() => {
                    card.classList.toggle('expanded');
                    document.body.classList.toggle('cat-modal-open', expanding);
                });
                t.finished.finally(() => {
                    if (!card.classList.contains('expanded'))
                        card.style.viewTransitionName = '';
                });
            } else {
                card.classList.toggle('expanded');
                document.body.classList.toggle('cat-modal-open', expanding);
            }
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                const exp = document.querySelector('.cat-card.expanded');
                if (exp) toggleCatCard(exp);
            }
        });

        /* Parallax on card hover */
        document.querySelectorAll('.cat-card').forEach(card => {
            const icon = card.querySelector('.cat-icon-wrap i');
            card.addEventListener('mousemove', e => {
                if (card.classList.contains('expanded')) return;
                const r = card.getBoundingClientRect();
                const x = (e.clientX - r.left) / r.width  - 0.5;
                const y = (e.clientY - r.top)  / r.height - 0.5;
                icon.style.transform =
                    `perspective(800px) rotateY(${x*18}deg) rotateX(${-y*18}deg) translateZ(25px) scale(1.1)`;
            });
            card.addEventListener('mouseleave', () => {
                if (!card.classList.contains('expanded')) icon.style.transform = '';
            });
        });

        /* =========================================================
           ADD TO CART
        ========================================================= */
        function addToCart(id) {
            fetch('/Cart/AddToCart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `sanPhamId=${id}&soLuong=1`
            })
            .then(r => r.json())
            .then(d => {
                showToast(d.message, d.success ? 'ok' : 'err');
                if (d.success) {
                    const b = document.querySelector('.cart-badge');
                    if (b) b.textContent = d.cartCount;
                }
            });
        }

        function showToast(msg, type) {
            const t = document.createElement('div');
            t.style.cssText =
                `position:fixed;top:20px;right:20px;z-index:9999;min-width:280px;
                 padding:12px 18px;border-radius:12px;font-family:'DM Sans',sans-serif;
                 font-size:0.9rem;color:#fff;backdrop-filter:blur(10px);
                 background:${type==='ok' ? 'rgba(30,90,200,0.9)' : 'rgba(200,40,40,0.9)'};
                 box-shadow:0 8px 24px rgba(0,0,0,0.35);
                 animation:catFadeUp 0.3s ease;`;
            t.innerHTML = `<i class="fas fa-${type==='ok'?'check-circle':'exclamation-circle'}"></i> ${msg}`;
            document.body.appendChild(t);
            setTimeout(() => t.remove(), 2800);
        }

        /* =========================================================
           CHATBOT
        ========================================================= */
        const chatToggle    = document.getElementById('chatbot-toggle');
        const chatContainer = document.getElementById('chatbot-container');
        const chatClose     = document.getElementById('chatbot-close');
        const chatInput     = document.getElementById('chatbot-input');
        const chatSend      = document.getElementById('chatbot-send');
        const chatMessages  = document.getElementById('chatbot-messages');

        chatToggle.addEventListener('click', () => {
            chatContainer.style.display = chatContainer.style.display === 'none' ? 'flex' : 'none';
            document.querySelector('.chatbot-badge').style.display = 'none';
        });
        chatClose.addEventListener('click', () => { chatContainer.style.display = 'none'; });

        async function sendMessage(text) {
            if (!text.trim()) return;
            appendMsg('user', text);
            chatInput.value = '';
            const tid = showTyping();
            try {
                const r = await fetch('@Url.Action("GetResponse", "Chat")', {
                    method:'POST',
                    headers:{'Content-Type':'application/json'},
                    body:JSON.stringify({message:text})
                });
                const d = await r.json();
                removeTyping(tid);
                appendMsg('bot', d.success ? d.reply : 'Lỗi: ' + d.reply);
            } catch {
                removeTyping(tid);
                appendMsg('bot','Không thể kết nối với máy chủ.');
            }
        }

        chatSend.addEventListener('click', () => sendMessage(chatInput.value));
        chatInput.addEventListener('keypress', e => { if (e.key==='Enter') sendMessage(chatInput.value); });
        window.sendQuickReply = t => sendMessage(t);

        function appendMsg(sender, text) {
            const d = document.createElement('div');
            d.className = `chatbot-message ${sender}-message`;
            d.innerHTML = `<div class="message-avatar"><i class="fas fa-${sender==='bot'?'robot':'user'}"></i></div>
                           <div class="message-content">${text}</div>`;
            chatMessages.appendChild(d);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function showTyping() {
            const id = 'ty-' + Date.now();
            const d = document.createElement('div');
            d.id = id; d.className = 'chatbot-message bot-message';
            d.innerHTML = `<div class="message-avatar"><i class="fas fa-robot"></i></div>
                <div class="message-content"><div class="typing-indicator">
                    <div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>
                </div></div>`;
            chatMessages.appendChild(d);
            chatMessages.scrollTop = chatMessages.scrollHeight;
            return id;
        }

        function removeTyping(id) { document.getElementById(id)?.remove(); }
    </script>
}
