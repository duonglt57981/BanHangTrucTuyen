@model List<BanMayAnh.Controllers.CartItemViewModel>

@{
    ViewData["Title"] = "Giỏ hàng";
    var tongTien = Model.Sum(x => x.ThanhTien);
    decimal phiVanChuyen = tongTien >= 5000000 ? 0 : 30000;
    decimal tongCong = tongTien + phiVanChuyen;
}

<style>
    .cart-container {
        padding: 3rem 0;
    }

    .cart-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 2rem;
        border-radius: 15px;
        margin-bottom: 2rem;
        text-align: center;
    }

        .cart-header h1 {
            margin: 0;
            font-weight: bold;
        }

    .cart-table {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        overflow: hidden;
        margin-bottom: 2rem;
    }

        .cart-table table {
            margin: 0;
        }

        .cart-table th {
            background: #f8f9fa;
            font-weight: bold;
            padding: 1rem;
            border: none;
        }

        .cart-table td {
            padding: 1.5rem 1rem;
            vertical-align: middle;
            border-top: 1px solid #dee2e6;
        }

    .product-info {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .product-image {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #6c757d;
        flex-shrink: 0;
        overflow: hidden;
    }

        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 10px;
        }

    .product-details h5 {
        margin: 0 0 0.3rem 0;
        font-weight: bold;
        color: #2c3e50;
        font-size: 0.95rem;
    }

    .product-details small {
        color: #7f8c8d;
    }

    /* Chi tiết sản phẩm tags */
    .spec-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
        margin-top: 0.4rem;
    }

    .spec-tag {
        font-size: 0.72rem;
        background: #e8f4fd;
        color: #1a6ea8;
        border-radius: 20px;
        padding: 0.15rem 0.55rem;
        font-weight: 500;
        white-space: nowrap;
    }

        .spec-tag.variant {
            background: #e8f5e9;
            color: #1b5e20;
            font-weight: 700;
        }

    .quantity-control {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .quantity-btn {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        border: 2px solid #667eea;
        background: white;
        color: #667eea;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s;
    }

        .quantity-btn:hover {
            background: #667eea;
            color: white;
        }

    .quantity-input {
        width: 60px;
        text-align: center;
        font-weight: bold;
        font-size: 1.1rem;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        padding: 0.3rem;
    }

    .price {
        font-size: 1.2rem;
        font-weight: bold;
        color: #e74c3c;
    }

    .btn-remove {
        background: #e74c3c;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        transition: all 0.3s;
    }

        .btn-remove:hover {
            background: #c0392b;
            transform: translateY(-2px);
        }

    .cart-summary {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        padding: 2rem;
        position: sticky;
        top: 20px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        padding: 0.8rem 0;
        border-bottom: 1px solid #e9ecef;
        font-size: 0.95rem;
    }

        .summary-row.total {
            font-size: 1.4rem;
            font-weight: bold;
            color: #2c3e50;
            border-bottom: none;
            margin-top: 0.5rem;
            padding-top: 1rem;
            border-top: 2px solid #dee2e6;
        }

            .summary-row.total .amount {
                color: #e74c3c;
            }

    .free-ship-badge {
        font-size: 0.78rem;
        background: #d4edda;
        color: #155724;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        margin-left: 0.4rem;
    }

    .btn-checkout {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 1rem;
        border-radius: 10px;
        font-weight: bold;
        font-size: 1.1rem;
        width: 100%;
        margin-top: 1rem;
        transition: all 0.3s;
    }

        .btn-checkout:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
            color: white;
        }

    .empty-cart {
        text-align: center;
        padding: 4rem 0;
    }

    .empty-cart-icon {
        font-size: 5rem;
        color: #e9ecef;
        margin-bottom: 2rem;
    }

    .btn-clear-cart {
        background: white;
        border: 2px solid #e74c3c;
        color: #e74c3c;
        border-radius: 10px;
        padding: 0.6rem 1.5rem;
        font-weight: 500;
        transition: all 0.3s;
    }

        .btn-clear-cart:hover {
            background: #e74c3c;
            color: white;
        }

    .ship-note {
        font-size: 0.8rem;
        color: #6c757d;
        text-align: center;
        margin-top: 0.5rem;
    }
</style>

<div class="cart-container">
    <div class="container">

        <!-- Header -->
        <div class="cart-header">
            <h1><i class="fas fa-shopping-cart"></i> Giỏ hàng của bạn</h1>
            <p class="mb-0">@Model.Count sản phẩm</p>
        </div>

        @if (Model.Any())
        {
            <div class="row">
                <!-- Cart Items -->
                <div class="col-lg-8">
                    <div class="cart-table">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">Đơn giá</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-center">Thành tiền</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr data-product-id="@item.SanPhamID">
                                        <td>
                                            <div class="product-info">
                                                <!-- Ảnh sản phẩm -->
                                                <div class="product-image">
                                                    @if (item.HinhAnh != null && item.HinhAnh.Length > 0)
                                                    {
                                                        <img src="data:image/jpeg;base64,@Convert.ToBase64String(item.HinhAnh)"
                                                             alt="@item.TenSanPham" />
                                                    }
                                                    else
                                                    {
                                                        <i class="fas fa-camera"></i>
                                                    }
                                                </div>

                                                <!-- Thông tin -->
                                                <div class="product-details">
                                                    <h5>@item.TenSanPham</h5>
                                                    <small><i class="fas fa-tag"></i> @item.DanhMuc</small>

                                                    @* Hiển thị thông tin ChiTietSanPham *@
                                                    <div class="spec-tags">
                                                        @if (!string.IsNullOrEmpty(item.BienThe))
                                                        {
                                                            <span class="spec-tag variant">
                                                                <i class="fas fa-circle" style="font-size:0.5rem;"></i>
                                                                @item.BienThe
                                                            </span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(item.DoPhanGiai))
                                                        {
                                                            <span class="spec-tag" title="Độ phân giải">
                                                                <i class="fas fa-image"></i> @item.DoPhanGiai
                                                            </span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(item.CamBien))
                                                        {
                                                            <span class="spec-tag" title="Cảm biến">
                                                                <i class="fas fa-microchip"></i> @item.CamBien
                                                            </span>
                                                        }
                                                        @if (!string.IsNullOrEmpty(item.Video))
                                                        {
                                                            <span class="spec-tag" title="Video">
                                                                <i class="fas fa-video"></i> @item.Video
                                                            </span>
                                                        }
                                                    </div>

                                                    <small class="d-block text-muted mt-1">
                                                        <i class="fas fa-box"></i>
                                                        Còn @item.TonKho sản phẩm
                                                    </small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <div class="price">@item.Gia.ToString("N0") đ</div>
                                        </td>
                                        <td class="text-center">
                                            <div class="quantity-control justify-content-center">
                                                <button class="quantity-btn" onclick="updateQuantity(@item.SanPhamID, -1)">
                                                    <i class="fas fa-minus"></i>
                                                </button>
                                                <input type="number" class="quantity-input"
                                                       value="@item.SoLuong"
                                                       min="1"
                                                       max="@item.TonKho"
                                                       onchange="updateQuantityDirect(@item.SanPhamID, this.value)" />
                                                <button class="quantity-btn" onclick="updateQuantity(@item.SanPhamID, 1)">
                                                    <i class="fas fa-plus"></i>
                                                </button>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <div class="price">@item.ThanhTien.ToString("N0") đ</div>
                                        </td>
                                        <td>
                                            <button class="btn-remove" onclick="removeFromCart(@item.SanPhamID)" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-between mt-3">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Tiếp tục mua hàng
                        </a>
                        <button class="btn btn-clear-cart" onclick="clearCart()">
                            <i class="fas fa-trash-alt"></i> Xóa toàn bộ giỏ hàng
                        </button>
                    </div>
                </div>

                <!-- Cart Summary -->
                <div class="col-lg-4">
                    <div class="cart-summary">
                        <h4 class="mb-4"><i class="fas fa-receipt"></i> Tổng đơn hàng</h4>

                        <!-- Thông tin giao hàng -->
                        <div class="mb-4">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">
                                    <i class="fas fa-phone text-primary"></i> Số điện thoại nhận hàng
                                </label>
                                <input type="text" id="txtSoDienThoai" class="form-control" placeholder="090x xxx xxx">
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">
                                    <i class="fas fa-map-marker-alt text-primary"></i> Địa chỉ giao hàng
                                </label>
                                <textarea id="txtDiaChi" class="form-control" rows="2" placeholder="Số nhà, tên đường, quận/huyện..."></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">
                                    <i class="fas fa-sticky-note text-primary"></i> Ghi chú (nếu có)
                                </label>
                                <input type="text" id="txtGhiChu" class="form-control" placeholder="Giao giờ hành chính...">
                            </div>
                        </div>

                        <!-- Tóm tắt giá -->
                        <div class="summary-row">
                            <span>Tạm tính:</span>
                            <span>@tongTien.ToString("N0") đ</span>
                        </div>
                        <div class="summary-row">
                            <span>
                                Phí vận chuyển:
                                @if (phiVanChuyen == 0)
                                {
                                    <span class="free-ship-badge">Miễn phí</span>
                                }
                            </span>
                            <span>@(phiVanChuyen == 0 ? "0 đ" : phiVanChuyen.ToString("N0") + " đ")</span>
                        </div>
                        <div class="summary-row total">
                            <span>Tổng cộng:</span>
                            <span class="amount">@tongCong.ToString("N0") đ</span>
                        </div>

                        @if (tongTien < 5000000)
                        {
                            <p class="ship-note">
                                <i class="fas fa-truck"></i>
                                Mua thêm <strong>@((5000000 - tongTien).ToString("N0")) đ</strong> để miễn phí vận chuyển!
                            </p>
                        }

                        <button class="btn btn-checkout" onclick="processCheckout()">
                            <i class="fas fa-credit-card"></i> XÁC NHẬN ĐẶT HÀNG
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="empty-cart">
                <div class="empty-cart-icon">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <h3>Giỏ hàng của bạn đang trống</h3>
                <p class="text-muted">Hãy thêm sản phẩm vào giỏ hàng để tiếp tục mua sắm!</p>
                <a asp-controller="Home" asp-action="Index"
                   class="btn btn-checkout" style="max-width:300px;margin:2rem auto;">
                    <i class="fas fa-shopping-bag"></i> Khám phá sản phẩm
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function updateQuantity(sanPhamId, change) {
            const row = document.querySelector(`tr[data-product-id="${sanPhamId}"]`);
            const input = row.querySelector('.quantity-input');
            const newValue = parseInt(input.value) + change;
            if (newValue < 1) return;
            if (newValue > parseInt(input.max)) {
                showToast('Không đủ hàng trong kho!', 'error');
                return;
            }
            updateQuantityDirect(sanPhamId, newValue);
        }

        function updateQuantityDirect(sanPhamId, soLuong) {
            fetch('/Cart/UpdateQuantity', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `sanPhamId=${sanPhamId}&soLuong=${soLuong}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) location.reload();
                else showToast(data.message, 'error');
            });
        }

        function removeFromCart(sanPhamId) {
            if (!confirm('Bạn có chắc muốn xóa sản phẩm này?')) return;
            fetch('/Cart/RemoveFromCart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `sanPhamId=${sanPhamId}`
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    updateCartCount(data.cartCount);
                    location.reload();
                }
            });
        }

        function clearCart() {
            if (!confirm('Bạn có chắc muốn xóa toàn bộ giỏ hàng?')) return;
            fetch('/Cart/ClearCart', { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    showToast(data.message, 'success');
                    location.reload();
                }
            });
        }

        function showToast(message, type) {
            const toast = document.createElement('div');
            toast.className = `alert alert-${type === 'success' ? 'success' : 'danger'} position-fixed`;
            toast.style.cssText = 'top:20px;right:20px;z-index:9999;min-width:300px;';
            toast.innerHTML = `<i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i> ${message}`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

        function updateCartCount(count) {
            const badge = document.querySelector('.cart-badge');
            if (badge) badge.textContent = count;
        }

        function processCheckout() {
            const diaChi = document.getElementById('txtDiaChi').value.trim();
            const soDienThoai = document.getElementById('txtSoDienThoai').value.trim();
            const ghiChu = document.getElementById('txtGhiChu').value.trim();

            if (!diaChi || !soDienThoai) {
                showToast('Vui lòng nhập đầy đủ Số điện thoại và Địa chỉ giao hàng!', 'error');
                return;
            }

            const btn = document.querySelector('.btn-checkout');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';

            fetch('/Cart/Checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ diaChiGiaoHang: diaChi, soDienThoai, ghiChu })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    alert('Chúc mừng! Đơn hàng của bạn đã được tiếp nhận.');
                    window.location.href = '/Home/LichSuDonHang';
                } else {
                    showToast(data.message, 'error');
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-credit-card"></i> XÁC NHẬN ĐẶT HÀNG';
                }
            })
            .catch(() => {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-credit-card"></i> XÁC NHẬN ĐẶT HÀNG';
            });
        }
    </script>
}
