@model IEnumerable<Assigmemt_Thanh_C4.Models.DataModels.NguoiDung>

@{
    ViewData["Title"] = "Quản lý Người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-header">
        <i class="fas fa-users"></i> Danh sách người dùng
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tên đăng nhập</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th>Địa chỉ</th>
                        <th>Quyền</th>
                        <th>Ngày tạo</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.NguoiDungID</strong></td>
                                <td>@item.TenDangNhap</td>
                                <td>@item.HoTen</td>
                                <td>@item.Email</td>
                                <td>@item.SoDienThoai</td>
                                <td>
                                    <small>@item.DiaChi</small>
                                </td>
                                <td>
                                    @if (item.Quyen?.TenQuyen == "Admin")
                                    {
                                        <span class="badge bg-danger">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">Khách hàng</span>
                                    }
                                </td>
                                <td>@item.NgayTao.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="fas fa-inbox fa-2x mb-3 d-block"></i>
                                Chưa có người dùng nào
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>