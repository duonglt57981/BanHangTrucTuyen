@model Assigmemt_Thanh_C4.Models.DataModels.DanhMuc

@{
    ViewData["Title"] = "Sửa danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-header">
        <i class="fas fa-edit"></i> Sửa danh mục: @Model.TenDanhMuc
    </div>
    <div class="card-body">
        <form asp-action="SuaDanhMuc" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="DanhMucID" />
            
            <div class="mb-3">
                <label asp-for="TenDanhMuc" class="form-label"></label>
                <input asp-for="TenDanhMuc" class="form-control" />
                <span asp-validation-for="TenDanhMuc" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MoTa" class="form-label"></label>
                <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Cập nhật
                </button>
                <a asp-action="DanhMuc" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Hủy
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}